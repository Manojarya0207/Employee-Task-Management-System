# =========================================================================
# TaskFlow environment variables — copy to `.env` and fill in for local dev.
# On Render, set these under Dashboard -> Service -> Environment instead.
# =========================================================================

# Signs the session cookie (NiceGUI's equivalent of Flask's SECRET_KEY).
# Generate a strong value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
# (SECRET_KEY is also accepted as an alias.)
STORAGE_SECRET=change-me-to-a-long-random-string

# Database connection string.
# Leave BLANK to use the local SQLite file at ./database/taskflow.db.
# Set to a PostgreSQL URL in production, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/taskflow
DATABASE_URL=

# Application environment: "development" or "production".
# On Render this is auto-detected, but you can set it explicitly.
ENVIRONMENT=development

# Port the server binds to. Render sets this automatically; locally defaults to 8080.
PORT=8080

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=DEBUG

# Optional: override the seeded default admin (only used on an empty database).
DEFAULT_ADMIN_ID=admin
DEFAULT_ADMIN_PASSWORD=Admin@123
